{
  "manifest_version": 3,
  "name": "ClipClean for TryHackMe",
  "version": "1.1.0",
  "description": "Toggle cleanup of TryHackMe glossary buttons so captured notes keep the text and formatting.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://tryhackme.com/*"],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "ClipClean for TryHackMe",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://tryhackme.com/room/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "clipclean-tryhackme@local"
    }
  }
}
